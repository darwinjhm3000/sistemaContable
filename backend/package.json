{
  "name": "sistema-contable-backend",
  "version": "1.0.0",
  "description": "Backend API para Sistema Contable Básico Colombia",
  "main": "dist/server.js",
  "scripts": {
    "start": "set TZ=America/Bogota&& node dist/server.js",
    "dev": "set TZ=America/Bogota&& ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "watch": "tsc --watch",
    "validar-db": "ts-node --transpile-only validar-db.ts",
    "validar-factura": "ts-node --transpile-only validar-factura-pdf.ts"
  },
  "keywords": [
    "contabilidad",
    "colombia",
    "puc",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@svgdotjs/svg.js": "^3.2.5",
    "@types/soap": "^0.21.0",
    "@types/xml2js": "^0.4.14",
    "axios": "^1.13.2",
    "canvas": "^3.2.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "mssql": "^10.0.1",
    "multer": "^2.0.2",
    "node-forge": "^1.3.3",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.4.530",
    "qrcode.react": "^4.2.0",
    "soap": "^1.6.3",
    "tesseract.js": "^7.0.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/mssql": "^9.1.8",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.19.27",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
